NEXT_PUBLIC_USE_API_PROXY="true"

# Public URL used when proxy mode is disabled (direct browser->backend calls)
NEXT_PUBLIC_API_BASE_URL="https://llm-policy-validator.onrender.com"

# Server-only URL used by the Next.js proxy route (/backend-api/*)
BACKEND_INTERNAL_API_URL="https://llm-policy-validator.onrender.com"


