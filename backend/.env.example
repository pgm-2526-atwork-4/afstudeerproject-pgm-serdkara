# Database
# Example (Neon/PostgreSQL):
# DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXP_HOURS=24
APPROVAL_TOKEN_MAX_AGE_SECONDS=604800
SUPER_ADMIN_EMAIL=admin@example.com

# Public URLs (production)
BACKEND_PUBLIC_URL=https://your-backend.onrender.com
FRONTEND_LOGIN_URL=https://your-frontend.vercel.app/login

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-frontend-git-main-yourteam.vercel.app

# Email provider (required for registration/approval email flow)
# Supported values: smtp, resend
MAIL_PROVIDER=smtp

# SMTP settings (used when MAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com

# Resend settings (used when MAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_API_BASE_URL=https://api.resend.com

# LLM Provider
OPENROUTER_API_KEY=
LLM_EXTRACTION_MODEL=openai/gpt-4o-mini
LLM_JUDGE_MODEL=anthropic/claude-3.5-sonnet-20240620

# Generation settings
LLM_EXTRACTION_TEMPERATURE=0.3
LLM_EXTRACTION_MAX_TOKENS=2000
LLM_EXTRACTION_TOP_P=0.9
LLM_JUDGE_MAX_TOKENS=1000
LLM_JUDGE_TOP_P=0.95
LLM_REQUEST_TIMEOUT_SECONDS=40
